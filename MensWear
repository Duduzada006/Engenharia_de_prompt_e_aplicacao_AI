        }

        .cart-item-name {
            font-weight: 600;
            color: #1a1a1a;
        }

        .cart-item-price {
            color: #00bcd4;
            font-weight: bold;
        }

        .cart-item-quantity {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .qty-btn {
            background: #f0f0f0;
            border: none;
            width: 25px;
            height: 25px;
            border-radius: 3px;
            cursor: pointer;
            transition: background 0.3s;
